# ──────────────────────────────────────────────
# Banco de dados
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ──────────────────────────────────────────────
# Better Auth
# ──────────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Criptografia (LGPD) — gere com os comandos abaixo
#
#   ENCRYPTION_KEY (AES-256-GCM, 32 bytes → 64 hex chars):
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
#   HMAC_KEY (HMAC-SHA256, 32 bytes → 64 hex chars):
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Atenção: use chaves diferentes para cada variável.
# Nunca reutilize nem compartilhe essas chaves.
# ──────────────────────────────────────────────
ENCRYPTION_KEY=
HMAC_KEY=

# ──────────────────────────────────────────────
# Usuário admin inicial (seed)
# ──────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@example.com
ADMIN_FULLNAME=Admin
